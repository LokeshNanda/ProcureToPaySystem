# dev|test|production. Production startup fails closed if SECRET_KEY below is
# still a known-insecure placeholder (default value, or containing "change-me"/"insecure").
ENVIRONMENT=dev
DATABASE_URL=postgresql+asyncpg://openp2p:openp2p@postgres:5432/openp2p
REDIS_URL=redis://redis:6379/0
# Production requires a real, unique SECRET_KEY (e.g. `openssl rand -hex 32`) — the
# app refuses to start with ENVIRONMENT=production if this is left as a placeholder.
SECRET_KEY=change-me
SECRET_ENCRYPTION_KEY=change-me-32-bytes-base64
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=/data/storage
FRONTEND_ORIGIN=http://localhost:5173
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin
